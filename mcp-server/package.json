{
  "name": "@olive/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Olive - couple notes and task management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "olive-mcp": "./dist/index.js"
  },
  "scripts": {
